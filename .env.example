# ============================================================
#  ИИ Бот №1 — environment configuration (copy to .env)
# ============================================================

# --- Telegram ---
BOT_TOKEN=
# Public https base used for webhook + Mini App; leave empty to use long-polling in dev
WEBHOOK_BASE_URL=
# Secret token Telegram echoes in X-Telegram-Bot-Api-Secret-Token (anti-forgery).
# Leave empty to auto-derive from BOT_TOKEN.
WEBHOOK_SECRET=
MINIAPP_URL=
# Comma-separated Telegram user_ids that always have premium / debug access
ADMIN_USER_IDS=
# Reject Mini App initData older than N seconds (replay protection). 0 disables.
INITDATA_MAX_AGE=86400

# --- Run mode ---
# polling | webhook
BOT_MODE=polling
ENV=dev
# Set true in ANY internet-facing deploy. Forces every process (api/worker/beat,
# not just the webhook bot) to fail closed on insecure secrets, require the admin
# IP allowlist + metrics token, and refuse the dev webapp bypass. Auto-detected
# when WEBHOOK_BASE_URL is set, but set it explicitly for a polling+public deploy.
PUBLIC_DEPLOY=false
LOG_LEVEL=INFO
# Local-only: accept Mini App API calls without Telegram initData (fixed test
# user). MUST be false whenever the API is publicly reachable. Only honoured when
# ENV is dev/test.
DEV_WEBAPP_BYPASS=false
SENTRY_DSN=

# --- Database / infra ---
DATABASE_URL=postgresql+asyncpg://aiobot:aiobot@postgres:5432/aiobot
REDIS_URL=redis://redis:6379/0
# Per-process DB pool. Total connections = (POOL_SIZE+MAX_OVERFLOW) × every
# process (each gunicorn worker + bot + each arq worker + beat). Keep under
# Postgres max_connections (200 in prod compose) OR use PgBouncer (below).
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
# Scale path: deploy the `pgbouncer` service (docker-compose.prod.yml), point
# DATABASE_URL at it (host=pgbouncer port=6432) and set DB_PGBOUNCER=true so the
# app drops its own pool and lets PgBouncer multiplex. Required for many replicas.
DB_PGBOUNCER=false
S3_ENDPOINT=http://minio:9000
# S3_KEY / S3_SECRET double as the MinIO ROOT credentials (docker-compose wires
# MINIO_ROOT_USER/PASSWORD to them). MUST be changed from minioadmin in prod
# (ENV != dev) — the app refuses to start otherwise. Password must be >= 8 chars.
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_BUCKET=aiobot
# Public base URL for serving stored objects (CDN / public MinIO). Required for
# img2img when an EXTERNAL provider must fetch the input; leave empty to use
# presigned URLs (worker-internal access only).
S3_PUBLIC_URL=

# --- AI providers (adapters degrade gracefully when key is empty) ---
OPENAI_API_KEY=
# Explicit OpenAI endpoint + image model. Set explicitly so the SDK never inherits
# an ambient OPENAI_BASE_URL from the shell environment (which could route the key
# to an unintended proxy). Override only for an OpenAI-compatible gateway.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1
OPENROUTER_API_KEY=      # optional OpenAI-compatible gateway; if set, text chat routes here
# OpenRouter key is free-tier ($0)? If true, ALL models route to one free model and
# the per-model cost multiplier is forced to 1 (no over-charging). Set false once funded.
OPENROUTER_FREE_TIER=true
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=
# LiteLLM proxy master key (docker-compose `litellm` service). Add this value as an
# AIAccount (kind=litellm, base_url=http://litellm:4000/v1) in the admin panel. The
# litellm container also reads the provider keys above (OPENAI/ANTHROPIC/GOOGLE/...).
# MUST be changed for production — the boot check rejects this exact default value.
LITELLM_MASTER_KEY=sk-litellm-change-me
KLING_API_KEY=
MINIMAX_API_KEY=
PIKA_API_KEY=
SEEDREAM_API_KEY=
BFL_API_KEY=
MIDJOURNEY_API_KEY=
SUNO_API_KEY=
# Optional: Suno aggregator base URL (default https://api.suno.ai/v1).
SUNO_BASE_URL=
# The EXACT model id your Suno aggregator expects for the version you sell (the UI
# advertises "Suno V5.5"). Set this so the sent model matches the label — otherwise
# the historical default "suno-v4" is used and users are downgraded. E.g. chirp-v4-5.
SUNO_MODEL=suno-v4
XAI_API_KEY=

# --- Payments ---
TRIBUTE_API_KEY=
# Tribute's REST/webhook field mapping is UNVERIFIED in code. Keep this false
# until you've confirmed the endpoints + field names against Tribute's live API;
# while false the gateway is inert (no checkout, no webhook applied) so an unsure
# mapping can't silently move money. Then set true to enable.
TRIBUTE_API_VERIFIED=false
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
# 54-ФЗ фискальные чеки. Off by default — turn on only when the merchant is under
# 54-ФЗ with an OFD attached. When false, no receipt is sent (behaviour unchanged).
YOOKASSA_RECEIPT_ENABLED=false
# vat_code: 1=без НДС, 2=НДС 0%, 3=10%, 4=20%, 5=10/110, 6=20/120.
YOOKASSA_VAT_CODE=1
# Optional СНО / tax system code (valid values 1–6); leave EMPTY to omit it from
# the receipt. FIX: AUDIT-L13 - was 0, which is not a valid YooKassa tax_system_code
# and would make receipt creation fail when YOOKASSA_RECEIPT_ENABLED=true.
YOOKASSA_TAX_SYSTEM_CODE=
# Fallback receipt customer contact (email or phone) used when the user has none.
YOOKASSA_RECEIPT_CONTACT=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
# Crypto payments via @CryptoBot (Crypto Pay). Token: @CryptoBot → Crypto Pay →
# Create App. Point the app's webhook at https://<domain>/webhook/crypto.
CRYPTO_PAY_TOKEN=
CRYPTO_PAY_TESTNET=false

# --- Business config (overridable in DB `pricing` table) ---
FREE_TEXT_WEEKLY=100
FREE_MINIAPP_WEEKLY=25
PREMIUM_DAILY=100
PREMIUM_X2_DAILY=200
GATE_CHANNEL=
SUPPORT_CONTACT=@lilcipher
BRAND_NAME=SUPER AI BOT

# --- Admin panel ---
# MUST be changed in prod (ENV != dev) or the app refuses to start.
ADMIN_JWT_SECRET=change-me-in-prod
ADMIN_IP_ALLOWLIST=
# Secret used to encrypt stored AI-account API keys at rest (falls back to
# ADMIN_JWT_SECRET if empty). Set a strong, dedicated value in prod.
ENC_SECRET=
# SSRF allowlist for admin-set AI account base_url values (comma-separated host
# suffixes). Empty = no allowlist, but literal non-public IPs are still rejected.
# Internal AI hosts allowed for provider base_url (comma-separated). These bypass the
# SSRF DNS check, so a provider can point at an in-network service. Defaults to the two
# bundled router services; add your own internal hosts as needed.
AI_BASE_URL_ALLOWLIST=omniroute,litellm
# CORS origins for the Mini App API (comma-separated). "*" is DEV-ONLY: in prod
# (ENV != dev) the app REFUSES TO START on "*" or empty — set the exact Mini App
# origin(s), e.g. CORS_ORIGINS=https://your.domain (the prod stack is same-origin).
CORS_ORIGINS=*

# --- Prod (docker-compose.prod.yml + Caddy) ---
DOMAIN=example.com
ADMIN_ALLOW_IP=203.0.113.10/32
POSTGRES_HOST=postgres
POSTGRES_USER=aiobot
POSTGRES_PASSWORD=aiobot
POSTGRES_DB=aiobot
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14

# --- Monitoring (docker-compose.monitoring.yml) ---
# FIX: AUDIT-17 - document required monitoring env vars
ALERT_BOT_TOKEN=           # required — Telegram bot token for alert delivery
ALERT_CHAT_ID=             # required — chat ID for alerts
GRAFANA_ADMIN_PASSWORD=    # required — Grafana login password
METRICS_TOKEN=             # recommended — bearer token for /metrics endpoint

# --- 2FA / MFA (FIX: DEPLOY-10) ---
# Comma-separated list of admin roles that MUST have 2FA enrolled.
# Empty = 2FA not required by default (set to "admin,superadmin" to enforce).
MFA_REQUIRED_ROLES=
