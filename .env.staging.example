# Staging environment — copy to .env.staging and fill in. Mirrors .env.example
# but isolated from production (separate DB/Redis/bot/keys).
ENV=staging
LOG_LEVEL=INFO

# Use a SEPARATE staging bot from @BotFather (never the prod bot).
BOT_TOKEN=CHANGE_ME_STAGING_BOT_TOKEN
BOT_MODE=polling
# For webhook mode on staging set these and BOT_MODE=webhook:
# WEBHOOK_BASE_URL=https://staging.example.com
MINIAPP_URL=

# Point AI at the local mock so staging costs nothing (uvicorn scripts.mock_ai_server:app):
OPENAI_API_KEY=mock-key
OPENAI_BASE_URL=http://host.docker.internal:8088/v1
# Or set real keys to validate live generation in staging.

# Infra (isolated staging instances — the staging compose project keeps volumes separate).
DATABASE_URL=postgresql+asyncpg://aiobot:aiobot@postgres:5432/aiobot
REDIS_URL=redis://redis:6379/0

# Secrets — staging-only values (still must be non-default; public webhook fails closed).
ADMIN_JWT_SECRET=CHANGE_ME_STAGING_SECRET
ENC_SECRET=CHANGE_ME_STAGING_ENC_SECRET
# FIX: AUDIT13-M14 - must NOT be '*'. ENV=staging is not dev/test, so the prod secret
# gate runs and `if "*" in cors_origin_list: raise` — a wildcard here makes the whole
# staging stack refuse to boot. Set the exact staging Mini App / admin origin(s).
CORS_ORIGINS=https://staging.example.com
AI_BASE_URL_ALLOWLIST=host.docker.internal,localhost

# Payments — use gateway TEST/sandbox credentials in staging.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
